---
import '../styles/index.css';

interface Props {
    title?: string;
}

const { title = "Cyber-Brief | Modern Defense" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <link rel="icon" type="image/png" href="/cyber-brief-logo-corral.png" />
    </head>
    <body>
        <header class="site-header">
            <nav class="nav-container">
                <a href="/" class="nav-logo">
                    <img src="/cyber-brief-logo-corral.png" alt="Shield" class="logo-img" />
                    <span class="logo-text">CYBER-BRIEF</span>
                </a>
                <div class="nav-links">
                    <a href="/intelligence" class="nav-link">intelligence</a>
                    <a href="/about" class="nav-link">about</a>
                </div>
            </nav>
        </header>
        <main>
            <slot />
        </main>
    </body>
</html>