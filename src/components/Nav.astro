---
<nav>
  <div class="nav-inner">
    <a class="nav-logo" href="/">
      <div class="logo-mark">
        <img src="/images/cyber-brief-logo-corral.png" alt="Cyber-Brief Logo">
      </div>

      <span class="logo-text">Cyber<span>-</span>Brief</span>
    </a>
    <div class="nav-right">
      <ul class="nav-links">
        <li><a href="/intelligence">Intelligence</a></li>
        <li><a href="/about">About</a></li>                
      </ul>
      
      <button class="theme-toggle" onclick="toggleTheme()">
        <span class="toggle-icon" id="toggle-icon">☀️</span>
        <span id="toggle-label">Light</span>
      </button>
    </div>
  </div>
</nav>
<style>
  nav {
    border-bottom: 1px solid var(--border);
    height: 64px;
    position: sticky;
    top: 0;
    z-index: 100;
    transition: background 0.3s, border-color 0.3s;
  }

  /* NAV INNER WRAPPER */
  .nav-inner {
    width: 100%;
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  /* LOGO AREA */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .logo-mark {
    width: auto;
    height: auto;
    background: none;
    padding: 0;
  }

  .logo-mark img {
    height: 36px;   /* perfect for a 64px nav bar */
    width: auto;
  }

  .logo-text {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--heading);
    transition: color 0.3s;
  }

  .logo-text span {
    color: var(--coral);
  }

  /* RIGHT SIDE OF NAV */
  .nav-right {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  /* NAV LINKS — HIDDEN ON MOBILE */
  .nav-links {
    display: none; /* mobile default */
    align-items: center;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.3s;
  }

  .nav-links a:hover {
    color: var(--heading);
  }

  /* SHOW NAV LINKS ON TABLET AND UP */
  @media (min-width: 640px) {
    .nav-links {
      display: flex;
    }
  }


  /* THEME TOGGLE */
  .theme-toggle {
    background: var(--bg2);
    border: 1px solid var(--border-bright);
    border-radius: 20px;
    padding: 5px 12px;
    display: flex;
    align-items: center;
    gap: 7px;
    cursor: pointer;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--body-text);
    transition: background 0.3s, border-color 0.3s, color 0.3s;
  }

  .toggle-icon {
    font-size: 13px;
    line-height: 1;
  }
</style>