---
const { briefs } = Astro.props;
---
<section class="archive-section">
  <div class="page">
    <div class="section-header">
      <div class="section-title">
        <div class="section-title-line"></div>
        <span class="section-title-text">Previous Intelligence Briefings</span>
      </div>
    </div>
    <div class="grid">
      {briefs.map((brief: any) => (
        <div class="col-12 sm-col-6">
          <a href={`/intelligence/${brief.slug}`} class="archive-card">
            {brief.data.image && (
              <div class="archive-thumb">
                <img src={brief.data.image} alt={brief.data.title} />
              </div>
            )}
            <div class="archive-tag">{brief.data.tag}</div>
            <h3 class="archive-h3">{brief.data.title}</h3>
            <p class="archive-excerpt">{brief.data.description}</p>
            <div class="archive-footer">
              <span class="archive-date">{brief.data.date}</span>
              <span class="archive-arrow">→</span>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .archive-section { padding-bottom: 56px; }

  .section-header {
    padding: 52px 0 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    margin-bottom: 24px;
    transition: border-color 0.3s;
  }

  .section-title {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-title-line {
    width: 20px;
    height: 1px;
    background: var(--coral);
  }

  .section-title-text {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
    transition: color 0.3s;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 16px;
  }

  .col-12 { grid-column: span 12; }

  @media (min-width: 640px) {
    .sm-col-6 { grid-column: span 6; }
  }

  .archive-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px;
    cursor: pointer;
    text-decoration: none;
    display: block;
    transition: border-color 0.2s, background 0.3s;
  }

  .archive-card:hover { border-color: var(--border-bright); }

  .archive-thumb {
    width: 100%;
    aspect-ratio: 16/7;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 4px;
    margin-bottom: 16px;
    overflow: hidden;
    transition: background 0.3s;
  }

  .archive-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .archive-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--coral);
    margin-bottom: 12px;
  }

  .archive-h3 {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 700;
    line-height: 1.25;
    color: var(--heading);
    margin-bottom: 10px;
    transition: color 0.3s;
  }

  .archive-excerpt {
    font-size: 15px;
    color: var(--body-text);
    line-height: 1.65;
    margin-bottom: 20px;
    transition: color 0.3s;
  }

  .archive-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .archive-date {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    color: var(--text-dim);
    transition: color 0.3s;
  }

  .archive-arrow {
    font-size: 14px;
    color: var(--text-dim);
    transition: color 0.3s;
  }

  .archive-card:hover .archive-arrow { color: var(--coral); }
</style>