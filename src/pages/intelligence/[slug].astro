---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Subscribe from '../../components/Subscribe.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const briefs = await getCollection('briefs');
  return briefs.map((brief) => ({
    params: { slug: brief.id },
    props: { brief },
  }));
}

const { brief } = Astro.props;
const { Content } = await render(brief);
---

<Layout
  title={`${brief.data.title} | Cyber-Brief`}
  description={brief.data.description}
  image={brief.data.image}
>
  <Nav />

  <div>
    <article class="brief-article">

      <div class="card-meta">
        <span class="card-tag">{brief.data.tag}</span>
        <span class="card-date">{brief.data.date}</span>
      </div>

      <h1>{brief.data.title}</h1>
      <p class="subtitle">{brief.data.subtitle}</p>

      {brief.data.image && (
        <div class="brief-image">
          <img src={brief.data.image} alt={brief.data.title} />
        </div>
      )}

      <div class="byline">
        <div class="byline-avatar">        
          <img src="/images/cyber-edge-profile.png" alt="Van Munoz">
        </div>
        <div>
          <div class="byline-name">Van Munoz</div>
          <div class="byline-title">Cyber Edge LLC · 25+ years in financial services security</div>
        </div>
      </div>

      <div class="bluf">
        <div class="bluf-label">Bottom Line Up Front</div>
        <p>{brief.data.bluf}</p>
      </div>

      <div class="brief-content">
        <Content />
      </div>

      <div class="back-link">
        <a href="/intelligence">← Back to all briefings</a>
      </div>

    </article>
  </div>

  <Subscribe />
  <Footer />
</Layout>

<style>
  .brief-article {
    max-width: 740px;
    margin: 0 auto;
    padding: 56px 0 48px;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
  }

  .card-tag {
    background: var(--coral-dim);
    color: var(--coral);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 2px;
    border: 1px solid rgba(224,90,56,0.3);
  }

  .card-date {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 14px;
    color: var(--text-dim);
    transition: color 0.3s;
  }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: 42px;
    font-weight: 700;
    line-height: 1.12;
    color: var(--heading);
    margin-bottom: 12px;
    letter-spacing: -0.01em;
    transition: color 0.3s;
  }

  .subtitle {
    font-size: 20px;
    color: var(--body-text);
    margin-bottom: 28px;
    line-height: 1.5;
    transition: color 0.3s;
  }

  .brief-image {
    width: 100%;
    aspect-ratio: 16/7;
    border-radius: 6px;
    margin-bottom: 28px;
    overflow: hidden;
    border: 1px solid var(--border-bright);
  }

  .brief-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .byline {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 28px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--border);
    transition: border-color 0.3s;
  }

  .byline-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--bg3);
    border: 1px solid var(--border-bright);
    flex-shrink: 0;
  }

  .byline-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .byline-name {
    font-size: 15px;
    font-weight: 500;
    color: var(--heading);
    line-height: 1.3;
    transition: color 0.3s;
  }

  .byline-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: var(--text-dim);
    transition: color 0.3s;
  }

  .bluf {
    background: var(--bg2);
    border-left: 3px solid var(--coral);
    padding: 20px 24px;
    border-radius: 0 6px 6px 0;
    margin-bottom: 36px;
    transition: background 0.3s;
  }

  .bluf-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--coral);
    margin-bottom: 10px;
  }

  .bluf p {
    font-size: 16px;
    color: var(--body-text);
    line-height: 1.75;
    transition: color 0.3s;
  }

  .brief-content {
    color: var(--body-text);
    font-size: 17px;
    line-height: 1.8;
  }

  .brief-content h2 {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--heading);
    margin: 48px 0 16px;
    letter-spacing: -0.01em;
    transition: color 0.3s;
  }

  .brief-content h3 {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--heading);
    margin: 32px 0 12px;
    transition: color 0.3s;
  }

  .brief-content p {
    margin-bottom: 20px;
    color: var(--body-text);
    transition: color 0.3s;
  }

  .brief-content strong {
    color: var(--heading);
    font-weight: 600;
  }

  .brief-content ul, .brief-content ol {
    margin: 0 0 20px 24px;
    color: var(--body-text);
  }

  .brief-content li { margin-bottom: 8px; }

  .brief-content a {
    color: var(--coral);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .back-link {
    margin-top: 56px;
    padding-top: 28px;
    border-top: 1px solid var(--border);
  }

  .back-link a {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--coral);
    text-decoration: none;
  }

  .back-link a:hover { opacity: 0.8; }
</style>