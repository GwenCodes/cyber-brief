---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CYBER-BRIEF | Modern Defense">
    <section class="main-content">
        
        <p class="welcome-text">
            Welcome to the inaugural issue of Cyber-Brief.
        </p>
        
        <article class="briefing-container">
            <div class="briefing-content">
                
                <span class="label-orange">STRATEGIC BRIEFING</span>
                
                <h1 class="briefing-title">The Enforcement Year</h1>
                
                <div class="briefing-image-wrapper">
                    <img src="/src/assets/img/The-Enforcement-Year-rect.png" alt="Tactical Visualization" />
                </div>
                
                <div class="article-body">
                    <p>
                        This issue explores how modern defense strategies are being dictated not just by CISOs, but by the actuarial tables of major global underwriters.
                    </p>
                </div>

            </div>
        </article>
        
    </section>
</Layout>