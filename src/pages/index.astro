---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import BriefCard from '../components/BriefCard.astro';
import Subscribe from '../components/Subscribe.astro';
import ArchiveGrid from '../components/ArchiveGrid.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allBriefs = await getCollection('briefs');
const sorted = allBriefs.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const latest = sorted[0];
const archive = sorted.slice(1);
---

<Layout
  title="Cyber-Brief | Strategic Risk Intelligence for Financial Leaders"
  description="High-signal cybersecurity briefings written for CISOs, executives, and board members navigating governance, compliance, and emerging threats in financial services."
>
  <div>
    <Nav />
    <Hero />

    <div class="border-b border-white/10">
      <div class="section-header">
        <div class="section-title">
          <div class="section-title-line"></div>
          <span class="section-title-text">Latest Strategic Briefing</span>
        </div>
        <a href="/intelligence" class="section-link">View all briefs →</a>
      </div>
    </div>

    <BriefCard
      title={latest.data.title}
      subtitle={latest.data.subtitle}
      tag={latest.data.tag}
      date={latest.data.date}
      image={latest.data.image}
      slug={latest.id}
      bluf={latest.data.bluf}
    />

    <Subscribe />

    {archive.length > 0 && <ArchiveGrid briefs={archive} />}

    <Footer />
  </div>
</Layout>

<style>
  .section-header {
    padding: 52px 0 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .section-title {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-title-line {
    width: 20px;
    height: 1px;
    background: var(--coral);
  }

  .section-title-text {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .section-link {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--coral);
    text-decoration: none;
  }
</style>